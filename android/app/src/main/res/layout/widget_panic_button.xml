<?xml version="1.0" encoding="utf-8"?>
<!-- 1x1 Panic Button Widget: circular emergency red button with shield icon -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_panic_button_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:padding="4dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:background="@drawable/widget_panic_button_bg"
        android:gravity="center">

        <ImageView
            android:id="@+id/widget_panic_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_widget_panic"
            android:contentDescription="Panic Button"
            android:tint="#FFFFFF" />

    </FrameLayout>

</RelativeLayout>
